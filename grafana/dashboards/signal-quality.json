{
  "uid": "crypto-signal-quality",
  "title": "Crypto Bot — Signal Quality",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "time": {"from": "now-24h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "heatmap",
      "title": "AI score distribution (all zones)",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 10},
      "targets": [
        {"expr": "sum by (le) (rate(ai_score_histogram_bucket[15m]))", "format": "heatmap", "refId": "A"}
      ],
      "options": {"calculate": false}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Median AI score per zone (p50)",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 10},
      "targets": [
        {"expr": "histogram_quantile(0.5, sum by (zone, le) (rate(ai_score_histogram_bucket[30m])))", "legendFormat": "{{zone}}", "refId": "A"}
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Confidence multiplier p50 / p95 per zone",
      "gridPos": {"x": 0, "y": 10, "w": 24, "h": 8},
      "targets": [
        {"expr": "histogram_quantile(0.5, sum by (zone, le) (rate(confidence_multiplier_bucket[30m])))", "legendFormat": "p50 {{zone}}", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (zone, le) (rate(confidence_multiplier_bucket[30m])))", "legendFormat": "p95 {{zone}}", "refId": "B"}
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "AI gate blocked reasons (10m rate)",
      "gridPos": {"x": 0, "y": 18, "w": 24, "h": 6},
      "targets": [
        {"expr": "sum by (zone, reason) (rate(ai_gate_blocked_total[10m])) * 600", "legendFormat": "{{zone}} / {{reason}}", "refId": "A"}
      ]
    },
    {
      "id": 5,
      "type": "heatmap",
      "title": "Fusion score distribution (post-gate)",
      "gridPos": {"x": 0, "y": 24, "w": 12, "h": 10},
      "targets": [
        {"expr": "sum by (le) (rate(fusion_score_bucket[15m]))", "format": "heatmap", "refId": "A"}
      ],
      "options": {"calculate": false}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Tech vs AI median per zone",
      "gridPos": {"x": 12, "y": 24, "w": 12, "h": 10},
      "targets": [
        {"expr": "histogram_quantile(0.5, sum by (zone, le) (rate(tech_score_bucket[30m])))", "legendFormat": "tech p50 {{zone}}", "refId": "A"},
        {"expr": "histogram_quantile(0.5, sum by (zone, le) (rate(ai_score_bucket[30m])))", "legendFormat": "ai p50 {{zone}}", "refId": "B"}
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Actions per zone (buy / sell / hold / blocked / skip)",
      "gridPos": {"x": 0, "y": 34, "w": 24, "h": 8},
      "targets": [
        {"expr": "sum by (zone, action) (rate(eval_action_by_zone_total[10m])) * 600", "legendFormat": "{{zone}} / {{action}}", "refId": "A"}
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Funnel block stages (10m rate)",
      "gridPos": {"x": 0, "y": 42, "w": 24, "h": 7},
      "targets": [
        {"expr": "sum by (stage) (rate(funnel_block_total[10m])) * 600", "legendFormat": "{{stage}}", "refId": "A"}
      ]
    }
  ]
}
